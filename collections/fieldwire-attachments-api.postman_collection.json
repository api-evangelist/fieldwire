  "info": {
    "_postman_id": "ec11970a-1950-45ac-ba12-d74f5414ae75",
    "name": "Fieldwire Attachments and Media API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Two-step direct-to-S3 upload flow for project attachments — photos, video,\nPDFs, drawings, spec pages — and the markup overlays drawn on top of them.\nClients first request a signed AWS S3 POST token (1-day TTL), then POST\nthe binary file directly to AWS, and finally register the attachment in\nFieldwire. Markups follow the GeoJSON Feature schema with `arrow`,\n`drawing`, `measurement`, and `text` styles.\n\n\nContact Support:\n Name: Fieldwire Developer Support",
      "type": "text/plain"
    }
  }
