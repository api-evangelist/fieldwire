      "name": "S3 Tokens",
      "description": {
        "content": "Short-lived signed AWS POST tokens for direct-to-S3 uploads.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "4c9ef663-51af-476e-a567-ce3f09c09b4a",
          "name": "Get AWS POST Token For Upload",
          "request": {
            "name": "Get AWS POST Token For Upload",
            "description": {
              "content": "Request a one-day signed AWS POST token that the client uses to upload\nthe binary directly to Amazon S3. The token contains the post URL,\npolicy, and form fields required for the S3 `POST object` operation;\nclients then add a `file` form field and POST to AWS directly.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "projects",
                ":project_id",
                "aws_post_tokens"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<long>",
                  "key": "project_id",
                  "description": "(Required) "
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"filename\": \"<string>\",\n  \"content_type\": \"<string>\",\n  \"size\": \"<long>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
